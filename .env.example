# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# -----------------------------------------------------------------------------
# Supabase
# Find these in your Supabase project: Settings > API
# -----------------------------------------------------------------------------

# Project URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose to the browser
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — bypasses Row Level Security and has full DB access.
# NEVER expose this in client-side code, logs, or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# JWT / Authentication
# -----------------------------------------------------------------------------

# Secret used to sign JWT tokens. Must be at least 32 characters long.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_random_32_character_string_minimum

# Signing algorithm — HS256 is the default and recommended value
JWT_ALGORITHM=HS256

# How long an access token stays valid (minutes). Default is 7 days (10080).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Tracker
# -----------------------------------------------------------------------------

# Camera device index passed to cv2.VideoCapture()
# 0 = default built-in webcam, 1 = first external/USB camera
CAMERA_INDEX=0

# Base URL of the backend API (no trailing slash)
BACKEND_URL=http://localhost:8000

# Bearer token the tracker sends to the backend API.
# Obtain by calling POST /auth/login and copying the returned access_token value.
AUTH_TOKEN=your_access_token_here

# -----------------------------------------------------------------------------
# Attention detection tuning (tracker)
# -----------------------------------------------------------------------------

# Eye Aspect Ratio below which eyes are considered closed (float, 0.0 – 1.0)
EAR_THRESHOLD=0.2

# Head yaw angle threshold for attention detection (degrees, 0 – 180)
# Smaller value = stricter; user is marked inattentive if abs(yaw) < this value
HEAD_YAW_THRESHOLD=160

# Head pitch angle threshold for attention detection (degrees)
# Larger value = stricter; user is marked inattentive if abs(pitch) > this value
HEAD_PITCH_THRESHOLD=45

# -----------------------------------------------------------------------------
# SMTP — reserved, not yet wired up
# These will be used for email notifications in a future release.
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
# Must be an integer (e.g. 587 for STARTTLS, 465 for SSL)
SMTP_PORT=587
FROM_EMAIL=no-reply@example.com

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# Matches the backend default (false). Set to true in production to enable per-IP rate limiting.
RATE_LIMIT_ENABLED=false
